# ConnectClaw Environment Variables
# Copy to .env and fill in:
#   cp .env.template .env

# LLM
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Feishu (Lark)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Vision Model (for image analysis)
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=

# Web Search (glyph TUI browser, free — https://github.com/k1y0miiii/glyph)
GLYPH_BIN=glyph
WEB_SEARCH_MAX_CHARS=8000
WEB_SEARCH_TIMEOUT=30

# RAG
CONNECTCLAW_RAG_ENABLED=0
