# ConnectClaw Configuration Template
# Copy this file to ~/.connectclaw/config.toml and fill in your values

[llm]
# LLM API key (required)
api_key = "${LLM_API_KEY}"
# LLM API base URL
base_url = "https://api.deepseek.com"
# Model ID to use
model_id = "deepseek-chat"

[feishu]
# Feishu/Lark app ID (required)
app_id = "${FEISHU_APP_ID}"
# Feishu/Lark app secret (required)
app_secret = "${FEISHU_APP_SECRET}"

[vision]
# Vision model API key (for image analysis, optional)
api_key = "${VISION_API_KEY}"
# Vision API base URL
base_url = ""
# Vision model ID
model_id = ""

[agent]
# Working directory (default: current directory)
cwd = "."
# Thinking/reasoning level: off, minimal, low, medium, high, xhigh
thinking_level = "off"

[session]
# Session storage directory
dir = "~/.connectclaw/sessions"

[rag]
# Enable RAG (requires lancedb, sentence-transformers, FlagEmbedding)
enabled = false
# Directory containing documents to index
docs_dir = ""
# LanceDB database path
db_path = "~/.connectclaw/rag_db"
# Number of candidates to retrieve from vector search
top_k = 20
# Number of results after reranking
top_n = 5

[web_search]
# Path to glyph binary (free TUI browser, Bing engine, no API key needed)
# Install: git clone https://github.com/k1y0miiii/glyph.git && cd glyph && cargo install --locked --path crates/app
glyph_bin = "glyph"
# Max characters in search/fetch response
max_chars = 8000
# Timeout in seconds
timeout = 30

[compaction]
# Enable automatic context compaction
enabled = true
# Token reserve before triggering compaction
reserve_tokens = 16384
# Tokens to keep in recent context after compaction
keep_recent_tokens = 20000

[memory]
# Layered memory: auto-extract facts/events/patterns from conversations,
# persist across sessions, inject into the USER MESSAGE (never system prompt,
# to keep DeepSeek's prefix cache hitting). View with /memory in Feishu.
enabled = true
# SQLite single-file store (zero external deps)
db_path = "~/.connectclaw/memory.db"
# Extract only every N turns to save API cost (and only after this many turns)
extract_min_turns = 3
extract_interval_turns = 5
# Token budget for recalled memories injected per turn
max_context_tokens = 2000
# Memories newer than this many days count as "recent" (shown in full detail)
recency_threshold_days = 7
# Use embeddings (BGE-M3) for semantic retrieval — auto-uses GPU if available.
# Needs `sentence-transformers` (in the [rag] optional group). Falls back to
# keyword search if unavailable, but keyword recall is poor for Chinese (no
# word segmentation), so embeddings are strongly recommended.
use_embeddings = true
# Background consolidation ("dreaming") interval, hours; also via /dream
dream_interval_hours = 24.0
# Strength half-life for time-based decay, days
decay_halflife_days = 30.0
# Enable episodic→semantic consolidation during dreaming
consolidation_enabled = true
